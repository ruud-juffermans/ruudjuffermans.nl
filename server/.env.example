PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# PostgreSQL connection string (required). docker-compose.dev.yml sets this for
# you; only needed when running the server directly on the host.
DATABASE_URL=postgresql://postgres:devpassword@localhost:5432/ruudjuffermans?schema=public

# Resend (https://resend.com) API key for sending email
RESEND_API_KEY=re_placeholder

# Address that contact-form submissions are sent to
CONTACT_EMAIL=you@example.com

# API key for the newsletter provider
NEWSLETTER_API_KEY=placeholder
