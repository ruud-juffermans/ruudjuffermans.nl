# ─────────────────────────────────────────────────────────────────────────────
# ruudjuffermans.nl — client-only since the platform consolidation. The site's
# backend (contact / newsletter / analytics + admin) moved into
# ../ruudjuffermans-server (api.ruudjuffermans.nl) as the "website" module;
# CONTACT_EMAIL, NEWSLETTER_API_KEY, SMTP_* and ADMIN_SERVICE_TOKEN now live in
# that project's env. The server/ directory here is legacy and no longer
# deployed.
# ─────────────────────────────────────────────────────────────────────────────

# --- Client (Next.js; NEXT_PUBLIC_* is baked in at build time) ---
# Platform API origin. Leave EMPTY in dev: the browser then calls same-origin
# /api/* and next.config.ts rewrites it to the local platform server on :4000.
NEXT_PUBLIC_API_URL=
# Canonical site URL (metadata + www→apex redirect).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
