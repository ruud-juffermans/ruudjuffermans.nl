# ruudjuffermans.nl — single root env file.
# Copy to .env and fill in your values:  cp .env.example .env
#
# Docker Compose auto-loads this root .env and interpolates the values below into
# both docker-compose.yml (prod) and docker-compose.dev.yml (dev). When running a
# service directly on the host, export it first:  set -a && . .env && set +a

# --- Server (Express API) ---
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# PostgreSQL connection string. The compose files build their own DATABASE_URL
# from POSTGRES_USER/POSTGRES_PASSWORD below, so this line is only used when
# running the server directly on the host.
DATABASE_URL=postgresql://postgres:devpassword@localhost:5432/ruudjuffermans?schema=public

# Resend (https://resend.com) API key for sending email
RESEND_API_KEY=re_placeholder

# Address that contact-form submissions are sent to
CONTACT_EMAIL=you@example.com

# API key for the newsletter provider
NEWSLETTER_API_KEY=placeholder

# Shared secret for the central admin app (ruudjuffermans-infra) to reach
# /api/v1/admin/*. Must match ADMIN_SERVICE_TOKEN in the admin app's env.
# Generate with: openssl rand -hex 32. Empty disables the admin API.
ADMIN_SERVICE_TOKEN=

# --- Shared Postgres (provisioned by the ruudjuffermans-infra stack) ---
# In production these must match ruudjuffermans-infra/.env.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=devpassword

# --- Client (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
